{
  "name": "@byimprint/mcp-server",
  "version": "1.0.1",
  "mcpName": "io.github.byimprint/intelligence",
  "description": "Open-source MCP client for byImprint creator-audience intelligence engine.",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./cli": {
      "types": "./dist/cli.d.ts",
      "import": "./dist/cli.js"
    }
  },
  "bin": {
    "imprint-mcp": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts --format esm --dts --clean --target node18",
    "test": "node --test --import tsx test/*.test.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "anthropic",
    "claude",
    "creator-economy",
    "youtube",
    "creator-intelligence",
    "imprint"
  ],
  "author": "James Hutchings <james@byimprint.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/byimprint/mcp-server.git"
  },
  "homepage": "https://byimprint.com/agents",
  "bugs": {
    "url": "https://github.com/byimprint/mcp-server/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^22.5.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
